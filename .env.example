# StormSense AI Supabase / deployment configuration

# Backend PostgreSQL connection string from Supabase Project Settings > Database.
# Use the pooler URL for Railway/serverless deployments when available.
DATABASE_URL=

# Alternative to DATABASE_URL; useful for local migration commands.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Supabase project API values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional database pool tuning.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

# Optional import location for MySQL Workbench dump files.
MYSQL_DUMP_DIR=C:\Users\USER\Documents\dumps\Dump20260607

# Existing StormSense auth token signing secret.
JWT_SECRET=

# Backend CORS configuration.
# Use comma-separated origins for production, e.g. deployed frontend and custom domains.
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=

# Frontend deployment variables are configured in Vercel / frontend .env files.
VITE_API_URL=
VITE_WS_URL=
VITE_APP_ENV=production
